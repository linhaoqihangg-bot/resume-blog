---
import { getCollection } from "astro:content";
import SectionHeading from "../../components/SectionHeading.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../utils/paths";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="博客" description="詹幸霖的技术博客，用于记录项目复盘、学习笔记和实习准备。">
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Blog"
        title="技术博客"
        description="这里会持续沉淀项目复盘、开发笔记和面试准备内容。"
      />
      <div class="mt-8 grid gap-5">
        {
          posts.map((post) => (
            <article class="rounded-lg border border-line bg-canvas p-5 transition hover:border-primary">
              <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <div>
                  <p class="text-sm text-muted">
                    {post.data.pubDate.toLocaleDateString("zh-CN")}
                  </p>
                  <h2 class="mt-2 text-xl font-bold text-ink">
                    <a class="focus-ring rounded-md hover:text-primary" href={withBase(`blog/${post.id}/`)}>
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="mt-3 leading-7 text-muted">{post.data.summary}</p>
                </div>
                <div class="flex shrink-0 flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-md bg-white px-2.5 py-1 text-xs font-medium text-primary shadow-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
