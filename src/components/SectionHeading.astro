---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  <p class="text-sm font-semibold text-accent">{eyebrow}</p>
  <h2 class="mt-2 text-2xl font-bold text-ink sm:text-3xl">{title}</h2>
  {description && <p class="mt-3 leading-7 text-muted">{description}</p>}
</div>
