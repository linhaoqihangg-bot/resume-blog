---
interface Props {
  project: {
    name: string;
    status: string;
    summary: string;
    stack: readonly string[];
    outcome: string;
    githubUrl?: string;
  };
}

const { project } = Astro.props;
---

<article class="rounded-lg border border-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <div class="flex flex-col gap-3">
    <div>
      <p class="text-xs font-semibold text-warm">{project.status}</p>
      <h3 class="mt-2 text-lg font-bold text-ink">{project.name}</h3>
    </div>
    <p class="leading-7 text-muted">{project.summary}</p>
    <div class="flex flex-wrap gap-2">
      {
        project.stack.map((item) => (
          <span class="rounded-md border border-blue-100 bg-blue-50 px-2.5 py-1 text-xs font-medium text-primary">
            {item}
          </span>
        ))
      }
    </div>
    <p class="border-t border-line pt-4 text-sm leading-6 text-muted">{project.outcome}</p>
    {
      project.githubUrl && (
        <a
          class="focus-ring inline-flex w-fit items-center rounded-md border border-primary px-3 py-2 text-sm font-semibold text-primary transition hover:bg-primary hover:text-white"
          href={project.githubUrl}
          target="_blank"
          rel="noreferrer"
        >
          查看 GitHub 源码
        </a>
      )
    }
  </div>
</article>
