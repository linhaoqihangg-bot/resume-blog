---
import { profile } from "../data/profile";
import { withBase } from "../utils/paths";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const navItems = [
  { label: "首页", href: withBase("") },
  { label: "项目", href: withBase("projects/") },
  { label: "博客", href: withBase("blog/") },
  { label: "简历", href: withBase("resume/") },
];

const isActive = (href: string) =>
  currentPath === href || (href !== withBase("") && currentPath.startsWith(href));
---

<header class="sticky top-0 z-20 border-b border-line bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href={withBase("")} class="focus-ring flex items-center gap-3 rounded-md">
      <span class="grid h-9 w-9 place-items-center rounded-md bg-accent text-sm font-bold text-white">
        Z
      </span>
      <span class="hidden leading-tight sm:block">
        <span class="block text-sm font-bold text-ink">{profile.name}</span>
        <span class="block text-xs text-muted">{profile.role}</span>
      </span>
    </a>

    <nav aria-label="主导航" class="flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "focus-ring rounded-md px-3 py-2 text-sm font-medium transition",
              isActive(item.href)
                ? "bg-blue-50 text-primary"
                : "text-muted hover:bg-slate-100 hover:text-ink",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
